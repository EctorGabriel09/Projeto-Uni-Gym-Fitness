@model UniGymFitness.Models.Plano

@{
    ViewData["Title"] = "Editar Plano";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container">

    <h2 class="fw-bold mb-4">Editar Plano</h2>

    <div class="card shadow">
        <div class="card-body">

            <form asp-controller="Planos" asp-action="Editar" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Preço</label>
                    <input asp-for="Preco" class="form-control" type="number" step="0.01" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <input asp-for="Descricao" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Benefícios</label>
                    <textarea asp-for="Beneficios" class="form-control" rows="4" required></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-controller="Planos" asp-action="Index" class="btn btn-secondary">
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-warning fw-bold">
                        Salvar Alterações
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>