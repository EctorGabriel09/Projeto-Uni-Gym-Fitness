@model UniGymFitness.Models.Produto
@using System.Globalization

@{
    ViewData["Title"] = "Editar Produto";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var precoFormatado = Model.Preco.ToString("0.00", CultureInfo.InvariantCulture);
}

<div class="container">

    <h2 class="fw-bold mb-4">Editar Produto</h2>

    <div class="card shadow">
        <div class="card-body">

            <form asp-controller="Produtos" asp-action="Editar" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Preço</label>
                    <input type="number"
                           name="Preco"
                           class="form-control"
                           step="0.01"
                           value="@precoFormatado"
                           required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Estoque</label>
                    <input asp-for="Estoque" class="form-control" type="number" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="4" required></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-controller="Produtos" asp-action="Index" class="btn btn-secondary">
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-warning fw-bold">
                        Salvar Alterações
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>